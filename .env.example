# ============================================================================
# Root environment for docker-compose.full-stack.yml
#
# Copy to .env and fill in real values. These feed both the backend services
# (JWT verification) and the frontend build args (Supabase client config).
# ============================================================================

# --- Supabase (centralized auth) -------------------------------------------
# Project URL + anon key are public (sent to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The Supabase project JWT secret — SERVER-SIDE ONLY. Every backend service
# verifies user tokens with this. Find it in:
# Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Legacy backend JWT (transition only) ----------------------------------
# Used by the legacy avry-backend auth tokens. Safe to keep during migration.
JWT_SECRET=test-secret-key-change-in-production

# --- Internal service token (optional) -------------------------------------
# Shared secret for trusted server-to-server (BFF) calls. Generate with:
#   openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# --- VPS Monitoring ---------------------------------------------------------
# Internal Prometheus URL (Docker service name). Used by the admin dashboard
# API routes to proxy PromQL queries. Only accessible within aivery-network.
PROMETHEUS_INTERNAL_URL=http://avry-prometheus:9090
