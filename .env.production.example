# AIVERY Production Environment Configuration
# Copy this to .env.production and fill in your actual secrets

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Single shared PostgreSQL database. All services (blog, careers) create
# their own tables within this database. No schema conflicts — table names
# are namespaced (blog_posts, blog_comments, vacancies, applications, etc.)
#
# For Supabase: use the connection string from
# Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis:6379

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=YOUR_JWT_SECRET_KEY_MIN_32_CHARACTERS_LONG
JWT_EXPIRATION=86400

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# ============================================================================
# CAREERS SERVICE - ENCRYPTION & EMAIL
# ============================================================================
# AES-256 encryption key for PII fields and CV files (64 hex chars = 32 bytes)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=YOUR_64_HEX_CHAR_ENCRYPTION_KEY

# SMTP for applicant email communication
SMTP_FROM_EMAIL=careers@aivory.id

# ============================================================================
# EXTERNAL SERVICES - PAYMENTS
# ============================================================================
MIDTRANS_SERVER_KEY=YOUR_MIDTRANS_SERVER_KEY
MIDTRANS_CLIENT_KEY=YOUR_MIDTRANS_CLIENT_KEY

# ============================================================================
# EXTERNAL SERVICES - AI/LLM
# ============================================================================
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# N8N AUTOMATION
# ============================================================================
N8N_URL=http://n8n:5678
N8N_API_KEY=YOUR_N8N_API_KEY

# ============================================================================
# DOMAIN & URLS
# ============================================================================
DOMAIN=aivory.id
NEXT_PUBLIC_BACKEND_URL=https://backend.aivory.id
NEXT_PUBLIC_API_URL=https://backend.aivory.id
NEXT_PUBLIC_CONSOLE_URL=https://console.aivory.id
NEXT_PUBLIC_APP_URL=https://app.aivery.id
NEXT_PUBLIC_LANDING_URL=https://aivory.id
NEXT_PUBLIC_ADMIN_URL=https://admin.aivory.id

# ============================================================================
# TRAEFIK & SSL
# ============================================================================
ACME_EMAIL=admin@aivory.id
CF_DNS_API_TOKEN=YOUR_CLOUDFLARE_DNS_API_TOKEN
CF_ZONE_API_TOKEN=YOUR_CLOUDFLARE_ZONE_API_TOKEN

# ============================================================================
# EMAIL CONFIGURATION (For notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@aivory.id

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=YOUR_SENTRY_DSN
LOG_FILE=/var/log/aivery/aivery.log

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================
# Backend Service
BACKEND_DEBUG=False
BACKEND_WORKERS=4

# Payments Service
PAYMENTS_DEBUG=False
PAYMENTS_WORKERS=2

# Diagnostics Service
DIAGNOSTICS_DEBUG=False
DIAGNOSTICS_WORKERS=2

# Blueprint Service
BLUEPRINT_DEBUG=False
BLUEPRINT_WORKERS=2

# Roadmap Service
ROADMAP_DEBUG=False
ROADMAP_WORKERS=2

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/backups/aivery

# ============================================================================
# SECURITY
# ============================================================================
CORS_ORIGINS=https://aivory.id,https://console.aivory.id,https://admin.aivory.id
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# FEATURES (Toggle on/off)
# ============================================================================
FEATURE_PAID_DIAGNOSTICS=true
FEATURE_WORKFLOW_AUTOMATION=true
FEATURE_BLUEPRINT_GENERATION=true
FEATURE_ADMIN_PANEL=true

# ============================================================================
# VPS DEPLOYMENT
# ============================================================================
VPS_HOST=your.vps.ip.address
VPS_SSH_KEY=/home/user/.ssh/id_rsa
VPS_USER=root
VPS_DEPLOY_DIR=/opt/aivery

# ============================================================================
# CLOUDFLARE
# ============================================================================
CLOUDFLARE_ACCOUNT_ID=YOUR_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=YOUR_API_TOKEN
CLOUDFLARE_ZONE_ID=YOUR_ZONE_ID
